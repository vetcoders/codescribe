{
  "build": {
    "beforeDevCommand": { "script": "trunk serve", "cwd": "." },
    "beforeBuildCommand": { "script": "trunk build", "cwd": "." },
    "devUrl": "http://localhost:8080",
    "frontendDist": "dist"
  },
  "productName": "CodeScribe",
  "version": "0.6.0",
  "identifier": "io.vetcoders.codescribe",
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "CodeScribe",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../models/whisper-large-v3-turbo-mlx-q8": "models/whisper-large-v3-turbo-mlx-q8"
    }
  }
}
