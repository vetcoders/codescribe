#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT/clients/node"

# Ensure Node available
if ! command -v node >/dev/null 2>&1; then
  echo "[!] Node.js is required (>=18)." >&2
  exit 1
fi

# Ensure ffmpeg available
if ! command -v ffmpeg >/dev/null 2>&1; then
  echo "[!] ffmpeg is required. Install with: brew install ffmpeg" >&2
  exit 1
fi

exec node ./vs-stream-client.mjs "$@"

