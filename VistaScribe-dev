#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

QUICKSTART="./scripts/quickstart_mac.sh"
RELEASE_SH="./packaging/release.sh"
BUILD_APP="./packaging/appwrap/build_wrapper_app.sh"
BUILD_DMG="./packaging/dmg/build_dmg.sh"
LOG_DIR="$ROOT_DIR/logs"
PID_DIR="$ROOT_DIR/.pids"

usage() {
  cat <<'EOF'
VistaScribe-dev — developer toolbox

Usage:
  VistaScribe-dev start [tray|backend|both]   Start in dev mode (foreground)
  VistaScribe-dev stop                        Stop tray/backend
  VistaScribe-dev status                      Show running processes
  VistaScribe-dev fresh [--yes]               Full cleanup + TCC reset
  VistaScribe-dev logs [--follow]             Tail dev log (logs/VistaScribe.log)
  VistaScribe-dev build-app                   Rebuild VistaScribe.app wrapper
  VistaScribe-dev build-dmg                   Rebuild wrapper + DMG image
  VistaScribe-dev release [--no-notary]       Run release pipeline (SIGN_IDENTITY env)
  VistaScribe-dev lint                        Ruff format/check
  VistaScribe-dev test                        uv run pytest -q
  VistaScribe-dev diag                        Show most recent diagnostics JSON
  VistaScribe-dev help                        This help

Tips:
  SIGN_IDENTITY="Developer ID Application: …" VistaScribe-dev release --no-notary
  VistaScribe-dev start both --fresh --yes    # one-shot fresh start
EOF
}

ensure_file() {
  if [[ ! -x "$1" ]]; then
    echo "[!] Required script '$1' not found or not executable." >&2
    exit 1
  fi
}

ensure_file "$QUICKSTART"

cmd=${1:-help}
shift || true

start_cmd() {
  local mode="both"
  local do_fresh=0
  local fresh_confirm=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      tray|backend|both)
        mode="$1"
        shift
        ;;
      --fresh)
        do_fresh=1
        if [[ "${2:-}" =~ ^(--yes|-y|yes)$ ]]; then
          fresh_confirm="--yes"
          shift 2
        else
          fresh_confirm=""
          shift 1
        fi
        ;;
      --yes|-y|yes)
        fresh_confirm="--yes"
        shift
        ;;
      *)
        echo "[!] Unknown option '$1'" >&2
        exit 2
        ;;
    esac
  done
  if [[ $do_fresh -eq 1 ]]; then
    fresh_cmd ${fresh_confirm:-}
  fi
  echo "==> Starting dev session ($mode)"
  "$QUICKSTART" --dev --mode "$mode"
}

stop_cmd() {
  "$QUICKSTART" --stop-all || true
}

status_cmd() {
  ./VistaScribe status
}

logs_cmd() {
  ./VistaScribe logs "$@"
}

fresh_cmd() {
  local confirm=${1:-}
  if [[ -n "$confirm" ]]; then
    case "$confirm" in
      --yes|-y|yes) confirm="--yes";;
      *) echo "[!] Use '--yes' to skip confirmation." >&2; exit 2;;
    esac
  fi
  "$QUICKSTART" --fresh ${confirm:+--yes}
}

build_app_cmd() {
  ensure_file "$BUILD_APP"
  "$BUILD_APP"
}

build_dmg_cmd() {
  ensure_file "$BUILD_APP"
  ensure_file "$BUILD_DMG"
  "$BUILD_APP"
  "$BUILD_DMG"
}

release_cmd() {
  ensure_file "$RELEASE_SH"
  "$RELEASE_SH" "$@"
}

lint_cmd() {
  uvx ruff format .
  uvx ruff check .
}

test_cmd() {
  uv run pytest -q
}

diag_cmd() {
  if [[ ! -d "$LOG_DIR" ]]; then
    echo "No diagnostics directory yet ($LOG_DIR)."; return
  fi
  local latest
  latest=$(ls -1t "$LOG_DIR"/diagnostics-*.json 2>/dev/null | head -n1 || true)
  if [[ -z "$latest" ]]; then
    echo "No diagnostics snapshots found. Run VistaScribe-dev start first."
  else
    echo "==> $latest"
    cat "$latest"
  fi
}

case "$cmd" in
  start)
    start_cmd "$@"
    ;;
  stop)
    stop_cmd
    ;;
  status)
    status_cmd
    ;;
  fresh)
    fresh_cmd "${1:-}"
    ;;
  logs)
    logs_cmd "$@"
    ;;
  build-app)
    build_app_cmd
    ;;
  build-dmg)
    build_dmg_cmd
    ;;
  release)
    release_cmd "$@"
    ;;
  lint)
    lint_cmd
    ;;
  test)
    test_cmd
    ;;
  diag)
    diag_cmd
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "[!] Unknown command '$cmd'" >&2
    usage
    exit 2
    ;;
esac
