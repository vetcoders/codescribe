# .gitignore

# python virtual environment
.venv/

# environment variables file
.env

# pycache
__pycache__/
*.pyc

# OS / editor
.DS_Store
# Share only JetBrains Run/Debug configurations
.idea/*
!.idea/runConfigurations/
!.idea/runConfigurations/*.xml
.vscode/
.junie/
src/vistascribe/assets/*
!src/vistascribe/assets/icon.png
!src/vistascribe/assets/voice_chat_lab.html
logs/

# runtime logs and state
logs/VistaScribe.log
.vista_scribe.lock
user-messages/

# build artifacts
packaging/dist/
packaging/build/
packaging/dmg/
dist/
build/
*.egg-info/

# local data and outputs
models/
outputs/
*.log
.pids/

# local email extraction leftovers (if present)
Raw/
extracted/

# archives and large binaries
*.zip

# misc
*.commands.txt
packaging/.DS_Store
/.fleet
/extracted_frames
/.codex
/.codescribe
/streaming-stt-inspirations
*.wav
*.txt
!docs/reports/*.txt
/.archive
/.gemini/
/.codex
/.gemini
