# Codescribe — exhaustive debug/developer environment template
#
# Registry source: docs/ENV_REGISTRY.toml. Every registered key appears
# exactly once below. All entries stay commented so copying this file
# changes no runtime behavior until a developer opts into a specific key.
#
# Runtime precedence: process env / ~/.codescribe/.env > settings.json > defaults.
# Secrets belong in Settings / macOS Keychain; placeholders are never real keys.

# =============================================================================
# STT / WHISPER
# =============================================================================
# BACKEND_MAX_UPLOAD_MB=20  # Default: 20 — Max audio upload size (MB) for cloud STT
# CODESCRIBE_APPLE_STT_ALLOW_DOWNLOAD=1  # Default: 1 — Allow SpeechAnalyzer bridge to auto-install missing Apple speech assets
# CODESCRIBE_APPLE_STT_BRIDGE=  # Default: unset — Optional SpeechAnalyzer bridge override; unset uses bundled Contents/MacOS helper before PATH
# CODESCRIBE_APPLE_STT_LOCALE=pl-PL  # Default: pl-PL — Locale override for Apple SpeechAnalyzer (e.g. pl-PL, en-US)
# CODESCRIBE_LAYERED_TRANSCRIPTION=off  # Default: off — Layered transcription gate: off or phase1..phase4
# CODESCRIBE_LOCAL_STT_FINAL_PASS=0  # Default: 0 — Run final-pass local STT on full audio (overrides streaming output)
# CODESCRIBE_MODEL_PATH=  # Default: unset — Override path to Whisper model directory
# CODESCRIBE_MODELS_DIR=  # Default: unset — Directory containing all models
# CODESCRIBE_ONNX_CPU_ONLY=0  # Default: 0 — Force ONNX to use CPU only (no GPU/Metal)
# CODESCRIBE_ONNX_MODEL_PATH=  # Default: unset — Custom path to ONNX Whisper model
# CODESCRIBE_ONNX_QUANT=  # Default: unset — ONNX quantization level (e.g. q4, q8)
# CODESCRIBE_ONNX_REPO=onnx-community/whisper-large-v3-turbo  # Default: onnx-community/whisper-large-v3-turbo — HuggingFace repo for ONNX model download
# CODESCRIBE_STT_COMMIT_MIN_INTERVAL_MS=180  # Default: 180 — Minimum interval between committed/final STT inference jobs in milliseconds
# CODESCRIBE_STT_ENGINE=auto  # Default: auto — STT engine: auto (Apple on supported macOS, Candle fallback), candle, onnx, or apple
# CODESCRIBE_STT_INITIAL_PROMPT_ENABLED=0  # Default: 0 — Opt-in gate for Candle Whisper runtime-lexicon initial_prompt. Default OFF after W2-F measured a 100% WER regression with the active prompt.
# CODESCRIBE_STT_MIN_INFER_INTERVAL_MS=90  # Default: 90 — Minimum interval between live preview STT inference jobs in milliseconds
# CODESCRIBE_STT_REFINE_MIN_INTERVAL_MS=240  # Default: 240 — Minimum interval between refinement STT inference jobs in milliseconds
# CODESCRIBE_STT_THERMAL_CRITICAL_MULT=4.0  # Default: 4.0 — Thermal multiplier for critical system thermal pressure
# CODESCRIBE_STT_THERMAL_FAIR_MULT=1.0  # Default: 1.0 — Thermal multiplier for fair system thermal pressure
# CODESCRIBE_STT_THERMAL_GOVERNOR_ENABLED=1  # Default: 1 — Enable thermal-aware STT scheduling backoff
# CODESCRIBE_STT_THERMAL_NOMINAL_MULT=0.0  # Default: 0.0 — Thermal duty-cycle multiplier for nominal system thermal pressure; 0.0 disables nominal backoff
# CODESCRIBE_STT_THERMAL_SERIOUS_MULT=2.0  # Default: 2.0 — Thermal multiplier for serious system thermal pressure
# CODESCRIBE_TOGGLE_FINAL_PASS=1  # Default: 1 — Use saved-WAV final-pass adjudication when stopping toggle dictation (0 restores preview-only stop path)
# CODESCRIBE_WHISPER_IDLE_UNLOAD_SECS=300  # Default: 300 — Unload idle Whisper engine after this many seconds (0 disables)
# CODESCRIBE_WHISPER_INITIAL_PROMPT=  # Default: unset — Initial prompt hint for Whisper decoding (ignored by ONNX adapter)
# LOCAL_MODEL=whisper-large-v3-turbo-mlx-q8  # Default: whisper-large-v3-turbo-mlx-q8 — Local Whisper model id (HF cache / embedded lookup)
# STT_API_KEY=<your-key>  # Default: unset — Cloud STT API key; prefer Settings / macOS Keychain
# STT_ENDPOINT=  # Default: unset — Cloud STT API endpoint (when USE_LOCAL_STT=0)
# USE_LOCAL_STT=1  # Default: 1 — Use local Whisper model (vs cloud)
# WHISPER_INITIAL_PROMPT=  # Default: unset — Legacy alias for CODESCRIBE_WHISPER_INITIAL_PROMPT Deprecated: use CODESCRIBE_WHISPER_INITIAL_PROMPT.
# WHISPER_LANGUAGE=auto  # Default: auto — Whisper transcription language hint. auto leaves detection to Whisper and applies on the next capture.
# WHISPER_MODEL=mlx-community/whisper-large-v3-mlx  # Default: mlx-community/whisper-large-v3-mlx — Whisper model id for cloud/multipart STT
# WHISPER_SERVER_URL=  # Default: unset — Legacy migration-only alias rewritten to STT_ENDPOINT Deprecated: use STT_ENDPOINT.

# =============================================================================
# VAD / SILENCE GATES
# =============================================================================
# CODESCRIBE_TAIL_DROP_ENABLED=1  # Default: 1 — Enable low-speech trailing-tail removal after the Silero gate
# CODESCRIBE_TAIL_SILENCE_SEC=2.0  # Default: 2.0 — Trailing silence threshold before the tail filter can drop a low-speech suffix
# CODESCRIBE_UTTERANCE_GAP_SEC=0.5  # Default: 0.5 — Silero utterance gap threshold in seconds

# =============================================================================
# AUDIO / RECORDING
# =============================================================================
# AUDIO_INPUT_DEVICE=  # Default: unset — Audio input device name (empty = system default)
# AUTO_SILENCE=1  # Default: 1 — Enable silence auto-stop in recorder
# BEEP_ON_START=1  # Default: 1 — Play beep when recording starts
# SOUND_NAME=Tink  # Default: Tink — macOS system sound name for beep
# SOUND_VOLUME=1.0  # Default: 1.0 — Sound volume (0.0-1.0)

# =============================================================================
# STREAMING / BUFFERING
# =============================================================================
# CODESCRIBE_BUFFER_DELAY_MS=280  # Default: 280 — Buffer delay in milliseconds (skipped for first emission to give instant feedback)
# CODESCRIBE_BUFFERED_CORRECTION_PREFIX=0.50  # Default: 0.50 — Prefix ratio required to accept buffered correction
# CODESCRIBE_BUFFERED_INTERIM_SEC=1.2  # Default: 1.2 — Interim emission cadence for buffered mode (sec)
# CODESCRIBE_BUFFERED_SILENCE_SEC=1.2  # Default: 1.2 — Silence duration before utterance flush in buffered mode (sec)
# CODESCRIBE_EMIT_WORDS_MAX=2  # Default: 2 — Maximum words emitted per tick (buffered mode)
# CODESCRIBE_MAX_INFERENCE_CONCURRENCY=1  # Default: 1 — Maximum number of concurrent inference tasks in streaming pipeline (clamped to 1-4)
# CODESCRIBE_STREAM_CHUNK_SEC=4.0  # Default: 4.0 — Streaming chunk duration in seconds (utterance cadence)
# CODESCRIBE_STREAM_DISABLE_EMBEDDINGS=0  # Default: 0 — Disable embedding-based deduplication
# CODESCRIBE_STREAM_FORCE_EMBEDDINGS=0  # Default: 0 — Force embeddings in tests (override test bypass)
# CODESCRIBE_STREAM_LEXICON=0  # Default: 0 — Apply lexicon post-processing to streaming output
# CODESCRIBE_STREAM_NOVELTY=0.12  # Default: 0.12 — Novelty threshold for deduplication
# CODESCRIBE_STREAM_OVERLAP_RATIO=0.25  # Default: 0.25 — Overlap ratio between chunks
# CODESCRIBE_STREAM_SIMILARITY=0.93  # Default: 0.93 — Similarity threshold for deduplication
# CODESCRIBE_STRIP_TRAILING_SMILEY_D=1  # Default: 1 — Strip trailing ':D' hallucinations from streaming output
# CODESCRIBE_TYPING_CPS=90  # Default: 90 — Typing speed in characters per second

# =============================================================================
# LLM LANES / PROVIDERS
# =============================================================================
# AI_ASSISTIVE_MAX_TOKENS=0  # Default: 0 — Max tokens for assistive LLM (0 = no limit)
# AI_FORMATTING_ENABLED=1  # Default: 1 — Enable AI formatting of transcripts
# AI_MAX_TOKENS=0  # Default: 0 — Max tokens for formatting LLM (0 = no limit)
# CODESCRIBE_AGENT_USE_PREVIOUS_RESPONSE_ID=1  # Default: 1 — Reuse previous OpenAI Responses API response_id to continue the same thread
# CODESCRIBE_AI_ATTEMPT_TIMEOUT_MS=30000  # Default: 30000 — Per-attempt timeout for non-Ollama AI requests (ms)
# CODESCRIBE_AI_CLIENT_TIMEOUT_MS=90000  # Default: 90000 — Reqwest client total request timeout for AI HTTP calls (ms)
# CODESCRIBE_AI_CONNECT_TIMEOUT_MS=5000  # Default: 5000 — Reqwest connect timeout for AI HTTP calls (ms)
# CODESCRIBE_AI_INTER_CHUNK_TIMEOUT_MS=30000  # Default: 30000 — Max idle time between SSE chunks before attempt is failed (ms)
# CODESCRIBE_AI_MAX_RETRIES=3  # Default: 3 — Max retries for AI formatting attempts (total attempts = retries + 1)
# CODESCRIBE_AI_OLLAMA_ATTEMPT_TIMEOUT_MS=5000  # Default: 5000 — Per-attempt timeout override for Ollama /api/chat requests (ms)
# CODESCRIBE_AI_POOL_IDLE_TIMEOUT_MS=90000  # Default: 90000 — Reqwest idle connection pool timeout for AI HTTP calls (ms)
# CODESCRIBE_AI_RETRY_DELAY_MS=2000  # Default: 2000 — Delay between AI retries (ms)
# CODESCRIBE_AI_TCP_KEEPALIVE_MS=30000  # Default: 30000 — Reqwest TCP keepalive interval for AI HTTP sockets (ms)
# CODESCRIBE_TRANSCRIPT_TAG_TEMPLATE=<codescribe mode="{mode}" lang="{lang}">\n{text}\n</codescribe>  # Default: <codescribe mode="{mode}" lang="{lang}">\n{text}\n</codescribe> — Template for transcript tagging; supports {text}, {mode}, and {lang} placeholders
# CODESCRIBE_TRANSCRIPT_TAGGING=0  # Default: 0 — Override settings.json to wrap pasted dictation transcripts in an epistemic Codescribe tag
# FORMATTING_LEVEL=medium  # Default: medium — AI formatting level: raw, medium, or creative
# LLM_ANTHROPIC_API_KEY=<your-key>  # Default: unset — Anthropic Messages API key account shared by Anthropic formatting and assistive lanes
# LLM_ANTHROPIC_ENDPOINT=https://api.anthropic.com/v1/messages  # Default: https://api.anthropic.com/v1/messages — Anthropic Messages API endpoint for the assistive/agent lane when LLM_ASSISTIVE_PROVIDER=anthropic-messages (override for proxies)
# LLM_API_KEY=<your-key>  # Default: unset — Shared/main OpenAI API key account; prefer Settings / macOS Keychain
# LLM_ASSISTIVE_API_KEY=<your-key>  # Default: unset — Assistive OpenAI API key account; prefer Settings / macOS Keychain
# LLM_ASSISTIVE_AUTH_MODE=api-key  # Default: api-key — Auth mode for assistive LLM provider: api-key or provider-account
# LLM_ASSISTIVE_ENDPOINT=  # Default: unset — Assistive/agent-lane endpoint override; falls back to shared LLM_ENDPOINT
# LLM_ASSISTIVE_MODEL=gpt-5.5  # Default: gpt-5.5 — Assistive/agent-lane model override
# LLM_ASSISTIVE_PROVIDER=openai-responses  # Default: openai-responses — Assistive/agent-lane provider id: openai-responses or anthropic-messages
# LLM_ASSISTIVE_TEMPERATURE=  # Default: unset — Assistive-lane temperature override; falls back to LLM_TEMPERATURE
# LLM_ENDPOINT=https://api.openai.com/v1/responses  # Default: https://api.openai.com/v1/responses — Shared OpenAI-compatible endpoint fallback for LLM lanes; normalized to /v1/responses
# LLM_FORMATTING_API_KEY=<your-key>  # Default: unset — Formatting-lane OpenAI API key account; prefer Settings / macOS Keychain
# LLM_FORMATTING_AUTH_MODE=api-key  # Default: api-key — Auth mode for formatting LLM provider: api-key or provider-account
# LLM_FORMATTING_ENDPOINT=  # Default: unset — Formatting-lane endpoint override; falls back to shared LLM_ENDPOINT
# LLM_FORMATTING_MODEL=gpt-4.1  # Default: gpt-4.1 — Formatting-lane model override
# LLM_FORMATTING_PROVIDER=openai-responses  # Default: openai-responses — Formatting-lane provider id: openai-responses or anthropic-messages
# LLM_FORMATTING_TEMPERATURE=0.1  # Default: 0.1 — Temperature for formatting mode
# LLM_HOST=  # Default: unset — Legacy migration-only host alias rewritten to LLM_ENDPOINT Deprecated: use LLM_ENDPOINT.
# LLM_MODEL=gpt-4.1  # Default: gpt-4.1 — Shared OpenAI model fallback for LLM lanes
# LLM_SERVER_URL=  # Default: unset — Legacy migration-only alias rewritten to LLM_ENDPOINT Deprecated: use LLM_ENDPOINT.
# LLM_TEMPERATURE=  # Default: unset — Shared temperature fallback; unset lets the selected model choose its default
# LLM_USE_STREAMING=1  # Default: 1 — Use streaming responses from LLM
# OLLAMA_HOST=  # Default: unset — Legacy migration-only Ollama host alias rewritten to LLM_ENDPOINT Deprecated: use LLM_ENDPOINT.
# OLLAMA_MODEL=  # Default: unset — Legacy migration-only Ollama model alias rewritten to LLM_MODEL Deprecated: use LLM_MODEL.
# TRANSCRIPT_SEND_MODE=streaming  # Default: streaming — How to send transcripts (streaming|end_of_utterance)

# =============================================================================
# ASSISTIVE / ATTACHMENTS
# =============================================================================
# AGENT_ENTER_SENDS=1  # Default: 1 — When true, Enter sends the agent message (Shift+Enter for newline). When false, Enter inserts newline (Cmd+Enter sends).
# AGENT_WORKSPACE_ROOTS=~/Git  # Default: ~/Git — Colon-separated workspace root directories the agent's list_projects tool scans (one level deep) to resolve a project name to an absolute path. Defaults to ~/Git.
# ASSISTIVE_CONTEXT_COPY_DELAY_MS=150  # Default: 150 — Delay in ms after Cmd+C before reading clipboard (macOS timing)
# ASSISTIVE_CONTEXT_MAX_CHARS=5000  # Default: 5000 — Max characters captured from selection for assistive context
# ASSISTIVE_CONTEXT_PROMPT_MAX_CHARS=5000  # Default: 5000 — Max characters captured from selection for assistive context prompt
# CODESCRIBE_ASSISTIVE_DEADLINE_SECS=15  # Default: 15 — Timeout in seconds for assistive tasks
# CODESCRIBE_ATTACH_PDF_OCR=1  # Default: 1 — Enable OCR fallback for PDF attachments
# CODESCRIBE_ATTACH_PDF_OCR_LANG=pol+eng  # Default: pol+eng — OCR language(s) for PDF attachments (tesseract)
# CODESCRIBE_ATTACH_PDF_PAGES=3  # Default: 3 — Max PDF pages to extract for attachments
# CODESCRIBE_DRAWER_INCLUDE_LEGACY=0  # Default: 0 — Include legacy transcript files in Drawer alongside ThreadStore entries (off by default).
# VOICE_CHAT_RECENT_CONTEXT_TTL_SECS=60  # Default: 60 — TTL for recent context in voice chat (seconds)
# VOICE_CHAT_RECENT_SELECTION_MAX_CHARS=5000  # Default: 5000 — Max characters captured from recent selection for voice chat

# =============================================================================
# UI / OVERLAY
# =============================================================================
# CODESCRIBE_OVERLAY_STABLE_PREVIEW=0  # Default: 0 — Use stable-word-only preview for live overlay text (0 = show exact live text)
# HOLD_BADGE_OFFSET_X=10  # Default: 10 — Hold badge X offset
# HOLD_BADGE_OFFSET_Y=-10  # Default: -10 — Hold badge Y offset
# HOLD_BADGE_SIZE=12  # Default: 12 — Hold badge size in pixels
# HOLD_INDICATOR=1  # Default: 1 — Show hold indicator badge
# OVERLAY_CUSTOM_X=0  # Default: 0 — Custom overlay X position (when mode=custom)
# OVERLAY_CUSTOM_Y=0  # Default: 0 — Custom overlay Y position (when mode=custom)
# OVERLAY_POSITION_MODE=snapped_top_right  # Default: snapped_top_right — Overlay position mode
# SHOW_DOCK_ICON=1  # Default: 1 — Show Dock icon
# SHOW_TRAY_GLYPH=1  # Default: 1 — Show tray icon glyph
# START_AT_LOGIN=0  # Default: 0 — Start Codescribe at login
# TRANSCRIPTION_OVERLAY_AUTO_HIDE_SECS=4  # Default: 4 — Auto-hide delay for transcription overlay in seconds
# TRANSCRIPTION_OVERLAY_ENABLED=1  # Default: 1 — Enable live non-assistive transcription overlay; when disabled the next capture uses a buffered no-overlay profile
# TRAY_START_ASSISTIVE=0  # Default: 0 — Start UI-initiated recording from the tray in the assistive lane instead of dictation

# =============================================================================
# HOTKEYS
# =============================================================================
# DOUBLE_TAP_INTERVAL_MS=200  # Default: 200 — Double-tap interval for toggle detection (ms)
# HOLD_EXCLUSIVE=1  # Default: 1 — Exclusive hold mode (no other keys during hold)
# HOLD_START_DELAY_MS=800  # Default: 800 — Delay before hold recording starts (ms)
# TOGGLE_SILENCE_SEC=5.0  # Default: 5.0 — Silence duration before sending a toggle utterance (seconds)

# =============================================================================
# CLIPBOARD
# =============================================================================
# RESTORE_CLIPBOARD=1  # Default: 1 — Restore clipboard after paste
# RESTORE_CLIPBOARD_DELAY_MS=1000  # Default: 1000 — Delay before restoring clipboard (ms)

# =============================================================================
# STORAGE / HISTORY
# =============================================================================
# CODESCRIBE_DATA_DIR=  # Default: unset — Override data directory (default: ~/.codescribe)
# CODESCRIBE_DISABLE_KEYCHAIN=0  # Default: 0 — Disable macOS Keychain access and use env-backed secrets for tests/CI
# CODESCRIBE_ENV_PATH=  # Default: unset — Override .env file path
# CODESCRIBE_NOTES_DIR=  # Default: unset — Override notes directory for Quick Notes
# DUMP_AUDIO_LOGS=1  # Default: 1 — Save audio files with transcripts
# HISTORY_ENABLED=1  # Default: 1 — Enable transcript history
# QUICK_NOTES_ENABLED=0  # Default: 0 — Enable Quick Notes (dictation saved to daily note)
# QUICK_NOTES_SAVE_ONLY=0  # Default: 0 — Quick Notes save-only mode (skip auto-paste)

# =============================================================================
# MODEL CACHE
# =============================================================================
# CODESCRIBE_HF_CACHE=  # Default: unset — Override HuggingFace cache root for model lookup
# HF_HOME=  # Default: unset — HuggingFace home directory (affects cache)
# HF_HUB_CACHE=  # Default: unset — HuggingFace hub cache directory
# HUGGINGFACE_HUB_CACHE=  # Default: unset — Alternate HF hub cache directory

# =============================================================================
# EMBEDDER
# =============================================================================
# CODESCRIBE_EMBEDDER_IDLE_UNLOAD_SECS=300  # Default: 300 — Unload idle embedder engine after this many seconds (0 disables)
# CODESCRIBE_EMBEDDER_PATH=  # Default: unset — Override path to E5 embedder model directory
# CODESCRIBE_EMBEDDER_REPO=intfloat/multilingual-e5-large  # Default: intfloat/multilingual-e5-large — HF repo for E5 embedder (used for embedding at build/runtime)

# =============================================================================
# TTS / VOICE
# =============================================================================
# CODESCRIBE_TTS_PATH=  # Default: unset — Override path to TTS model directory

# =============================================================================
# QUALITY / DAEMON
# =============================================================================
# QUALITY_DEBUG_MODE=0  # Default: 0 — Verbose quality loop logging
# QUBE_DAEMON_AUTOSTART=0  # Default: 0 — Start bundled qube-daemon on app launch when available; otherwise preserve the preference for external launchd/shell automation
# QUBE_DAEMON_USE_CLOUD_STT=0  # Default: 0 — Force cloud STT for quality loop without changing app USE_LOCAL_STT

# =============================================================================
# BUILD-TIME
# =============================================================================
# CODESCRIBE_EMBED_MODEL=  # Default: unset — Whisper model to embed (HF repo or local path)
# CODESCRIBE_EMBED_TTS=0  # Default: 0 — Embed TTS model in binary
# CODESCRIBE_EMBED_WHISPER=0  # Default: 0 — Opt-in: embed Whisper model in binary (distribution builds); default loads from HF cache at runtime
# CODESCRIBE_NO_EMBED=0  # Default: 0 — Skip embedding Whisper model in binary

# =============================================================================
# DEBUG / LOGGING
# =============================================================================
# CODESCRIBE_DEBUG_TOKENS=0  # Default: 0 — Debug token output from Whisper
# CODESCRIBE_STREAM_LOG=0  # Default: 0 — Enable streaming debug log
# CODESCRIBE_STREAM_LOG_PATH=  # Default: unset — Path for streaming debug log
# CODESCRIBE_UI_TESTS=0  # Default: 0 — Enable AppKit/UI tests gated by CODESCRIBE_UI_TESTS
# LOG_LEVEL=info  # Default: info — Legacy logging filter (used if RUST_LOG is unset)
# RUST_LOG=  # Default: unset — Rust logging filter
# TRACE_PIPELINE=0  # Default: 0 — Enable verbose pipeline tracing

# =============================================================================
# OPT-IN TEST / BENCH
# =============================================================================
# BENCH_STT_FIXTURES=auto  # Default: auto — scripts/bench-stt.sh fixture source selector: auto, historical, or repo
# BENCH_STT_LANGUAGE=pl  # Default: pl — scripts/bench-stt.sh Whisper language hint for bench probes
# BENCH_STT_LATENCY_MANIFEST=  # Default: unset — Internal bench hook: fixture manifest path for the scheduler-lane latency probe
# BENCH_STT_LATENCY_OUT=  # Default: unset — Internal bench hook: TSV output path for the scheduler-lane latency probe
# BENCH_STT_LIMIT=10  # Default: 10 — scripts/bench-stt.sh fixture limit for historical corpus runs
# BENCH_STT_OUT=  # Default: unset — scripts/bench-stt.sh output directory under ~/.codescribe
# CODESCRIBE_BENCH_FORCE_PROMPT=0  # Default: 0 — scripts/bench-stt.sh prompted-WER probe: generate deterministic fixture prompt when runtime prompt is disabled or empty
# CODESCRIBE_BENCH_PROMPT_MAX_WER_DELTA_PP=5.0  # Default: 5.0 — scripts/bench-stt.sh prompted-WER probe: fail when active prompt increases WER above this percentage-point threshold
# CODESCRIBE_BENCH_RUNTIME_PROMPT_TERM_LIMIT=  # Default: unset — scripts/bench-stt.sh prompted-WER probe: trim active runtime prompt to the first N deterministic terms; unset uses the full prompt
# CODESCRIBE_E2E_CORPUS=0  # Default: 0 — Enable the real WAV/TXT corpus regression probe
# CODESCRIBE_E2E_CORPUS_DATE=  # Default: unset — Optional date filter for the corpus regression probe
# CODESCRIBE_E2E_CORPUS_DIR=  # Default: unset — Optional corpus directory override for WAV/TXT regression pairs
# CODESCRIBE_E2E_CORPUS_LANGUAGE=  # Default: unset — Optional Whisper language hint for corpus regression runs
# CODESCRIBE_E2E_CORPUS_LIMIT=3  # Default: 3 — Maximum number of corpus pairs processed by one E2E run
# CODESCRIBE_E2E_CORPUS_MAX_REGRESSION=0.05  # Default: 0.05 — Maximum accepted WER/CER regression ratio for the corpus probe
# CODESCRIBE_E2E_LANG=pl  # Default: pl — Language hint for opt-in local STT E2E tests
# CODESCRIBE_E2E_MIC=0  # Default: 0 — Enable opt-in E2E tests that capture from a real microphone
# CODESCRIBE_E2E_MIC_LANGUAGE=  # Default: unset — Optional language hint for real-microphone E2E tests
# CODESCRIBE_E2E_MIC_SEC=6.0  # Default: 6.0 — Recording duration in seconds for the real-microphone VAD probe
# CODESCRIBE_E2E_OLLAMA=0  # Default: 0 — Enable the real local-Ollama conversation continuity test
# CODESCRIBE_E2E_RUN_MEDIUM=1  # Default: 1 — Include the medium audio fixture in the example STT E2E run
# CODESCRIBE_E2E_STT=0  # Default: 0 — Enable heavy local Whisper STT E2E suites

# =============================================================================
# SYSTEM / SHELL
# =============================================================================
# EDITOR=  # Default: unset — Preferred editor (used by --config)
# HOME=  # Default: unset — Home directory (shell-provided)
# VISUAL=  # Default: unset — Preferred visual editor (fallback for EDITOR)
