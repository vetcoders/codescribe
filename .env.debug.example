# CodeScribe Env Debug / Developer (exhaustive)
# Copy to ~/.codescribe/.env or point via CODESCRIBE_ENV_PATH
# This file lists ALL known env vars used by CodeScribe (runtime + build + tests).
# Values shown are safe defaults/examples. Remove what you don't need.

# =============================================================================
# PATHS / CONFIG LOCATIONS
# =============================================================================
# CODESCRIBE_DATA_DIR=~/.codescribe              # Override data dir
# CODESCRIBE_APP_DIR=~/.codescribe               # Alias for data dir
# CODESCRIBE_ENV_PATH=~/.codescribe/.env         # Explicit .env path
# CODESCRIBE_ENV_TEMPLATE=./.env.example         # Template used to auto-create .env
# CODESCRIBE_MODELS_DIR=~/.codescribe/models     # External models directory

# =============================================================================
# EMBEDDED MODEL (BUILD-TIME)
# =============================================================================
# CODESCRIBE_EMBED_MODEL=./models/whisper-large-v3-turbo-mlx-q8   # Embed this model at build
# CODESCRIBE_NO_EMBED=1                                           # Build WITHOUT embedding
# (When no embed, runtime must set CODESCRIBE_MODEL_PATH)

# =============================================================================
# LOCAL WHISPER / STT (RUNTIME)
# =============================================================================
# CODESCRIBE_MODEL_PATH=/path/to/model                             # Override embedded model
LOCAL_MODEL=whisper-large-v3-turbo-mlx-q8                          # Local model name (if multiple)
WHISPER_MODEL=mlx-community/whisper-large-v3-mlx                   # External HF model name
WHISPER_LANGUAGE=pl                                                 # pl | en (auto maps to pl)
USE_LOCAL_STT=1                                                     # 1=prefer local, 0=cloud only
# CODESCRIBE_MODEL_DIR=...                                          # Set by build.rs (internal)

# =============================================================================
# CLOUD STT (FALLBACK / REFERENCE)
# =============================================================================
# STT_ENDPOINT=https://api.libraxis.cloud/v1/audio/transcriptions
# STT_API_KEY=your-stt-api-key
# WHISPER_SERVER_URL=https://api.libraxis.cloud/v1/audio/transcriptions   # legacy alias
# BACKEND_MAX_UPLOAD_MB=25

# =============================================================================
# LLM / RESPONSES API (FORMATTING + ASSISTIVE)
# Contract: LLM_{FORMATTING,ASSISTIVE}_{ENDPOINT,MODEL,API_KEY}
# Fallback: LLM_{ENDPOINT,MODEL,API_KEY}
# =============================================================================
LLM_ENDPOINT=https://api.openai.com/v1/responses
LLM_MODEL=gpt-4.1-mini
# LLM_API_KEY=sk-...

# Formatting overrides
# LLM_FORMATTING_ENDPOINT=
# LLM_FORMATTING_MODEL=
# LLM_FORMATTING_API_KEY=

# Assistive overrides
# LLM_ASSISTIVE_ENDPOINT=
# LLM_ASSISTIVE_MODEL=
# LLM_ASSISTIVE_API_KEY=

# Temperatures (mode-aware)
# LLM_TEMPERATURE=0.2
# LLM_FORMATTING_TEMPERATURE=0.1
# LLM_ASSISTIVE_TEMPERATURE=0.3

# Streaming in LLM responses
# LLM_USE_STREAMING=1      # 1/true enables streaming responses

# Legacy / compatibility
# LLM_HOST=http://localhost:11434/v1/responses    # legacy alias for LLM_ENDPOINT
# LLM_SERVER_URL=http://localhost:11434/v1/responses
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# =============================================================================
# AI FORMATTING / ASSISTIVE SETTINGS
# =============================================================================
AI_FORMATTING_ENABLED=1
# AI_PROVIDER=harmony            # legacy (harmony|ollama)
# AI_MAX_TOKENS=0                # 0 = no limit
# AI_ASSISTIVE_MAX_TOKENS=0       # 0 = no limit

# end_of_utterance | streaming:
TRANSCRIPT_SEND_MODE=end_of_utterance

# Retry policy for AI calls
# CODESCRIBE_AI_MAX_RETRIES=2
# CODESCRIBE_AI_RETRY_DELAY_MS=500
# CODESCRIBE_AI_ATTEMPT_TIMEOUT_MS=5000

# =============================================================================
# STREAMING / CHUNKING / BUFFERED MODE (IMPORTANT)
# =============================================================================
CODESCRIBE_STREAM_CHUNK_SEC=15.0       # Chunk size in seconds (0.5..30)
CODESCRIBE_STREAM_OVERLAP_RATIO=0.25   # Overlap ratio (0.05..0.8) of chunk size
CODESCRIBE_BUFFERED_STREAM=1           # 1 enables VAD buffered mode (default)
# CODESCRIBE_EVENT_PIPELINE=0          # 1 enables event-based pipeline (experimental)
CODESCRIBE_BUFFER_DELAY_MS=3000        # Delay before emitting buffered text
CODESCRIBE_TYPING_CPS=30               # Emission speed in buffered mode

# VAD for buffered mode (Silero neural network)
CODESCRIBE_VAD_THRESHOLD=0.5
CODESCRIBE_VAD_MIN_SPEECH_SEC=0.1
CODESCRIBE_VAD_MAX_SILENCE_SEC=1.2
CODESCRIBE_VAD_MAX_UTTERANCE_SEC=60
CODESCRIBE_VAD_PRE_ROLL_SEC=0.3

# =============================================================================
# STREAM POSTPROCESS (REPETITION / GATING)
# =============================================================================
# CODESCRIBE_STREAM_SIMILARITY=0.90    # similarity threshold
# CODESCRIBE_STREAM_NOVELTY=0.20       # novelty threshold
# CODESCRIBE_STREAM_DISABLE_EMBEDDINGS=0

# =============================================================================
# STREAM LOGGING
# =============================================================================
# CODESCRIBE_STREAM_LOG=0
# CODESCRIBE_STREAM_LOG_PATH=/tmp/codescribe_stream.log

# =============================================================================
# AUDIO INPUT
# =============================================================================
# AUDIO_INPUT_DEVICE=MacBook Pro Microphone
AUTO_SILENCE=0

# =============================================================================
# HOTKEYS
# =============================================================================
HOLD_MODS=ctrl                 # ctrl | ctrl_alt | ctrl_shift | ctrl_cmd
HOLD_EXCLUSIVE=1               # 1 ignores extra modifiers during hold (default)
TOGGLE_TRIGGER=double_option   # double_option | double_ralt | none
HOLD_START_DELAY_MS=800

# =============================================================================
# UI / OVERLAYS / FEEDBACK
# =============================================================================
SHOW_TRAY_GLYPH=1
HOLD_INDICATOR=1# bool (legacy string values ignored)
HOLD_BADGE_SIZE=12
HOLD_BADGE_OFFSET_X=10
HOLD_BADGE_OFFSET_Y=-10
OVERLAY_POSITION_MODE=snapped_top_right   # snapped_top_right | custom
# OVERLAY_CUSTOM_X=0
# OVERLAY_CUSTOM_Y=0

BEEP_ON_START=1
SOUND_NAME=Tink
SOUND_VOLUME=1.0

# =============================================================================
# CLIPBOARD
# =============================================================================
RESTORE_CLIPBOARD=1
RESTORE_CLIPBOARD_DELAY_MS=1000

# =============================================================================
# HISTORY / STORAGE
# =============================================================================
HISTORY_ENABLED=1
DUMP_AUDIO_LOGS=1

# =============================================================================
# QUALITY LOOP / REPORTING
# =============================================================================
# QUALITY_DEBUG_MODE=1
# CODESCRIBE_QUALITY_DISABLE_CLOUD=1

# =============================================================================
# VOICE CHAT BACKEND (LOCAL DEV)
# =============================================================================
# CODESCRIBE_BACKEND_URL=http://127.0.0.1:8237

# =============================================================================
# DEBUG / TEST FLAGS (E2E)
# =============================================================================
# CODESCRIBE_DEBUG_TOKENS=1
# CODESCRIBE_STREAM_FORCE_EMBEDDINGS=1

# CODESCRIBE_E2E_STT=1
# CODESCRIBE_E2E_DAEMON=1
# CODESCRIBE_E2E_MIC=1
# CODESCRIBE_E2E_MIC_LANGUAGE=en
# CODESCRIBE_E2E_LANG=en
# CODESCRIBE_E2E_OLLAMA=1
# CODESCRIBE_E2E_RUN_MEDIUM=1
# CODESCRIBE_E2E_CORPUS=1
# CODESCRIBE_E2E_CORPUS_DATE=2026-01-17
# CODESCRIBE_E2E_CORPUS_LIMIT=3
# CODESCRIBE_E2E_CORPUS_MAX_REGRESSION=0.05
# CODESCRIBE_E2E_CORPUS_LANGUAGE=pl
# CODESCRIBE_E2E_CORPUS_DIR=/path/to/corpus

# =============================================================================
# LOGGING (legacy; prefer RUST_LOG)
# =============================================================================
# LOG_LEVEL=INFO   # TRACE | DEBUG | INFO | WARN | ERROR
# RUST_LOG=info
