---
import { asset } from '../lib/asset';
---

<section class="section agentchat" data-screen-label="Agent chat" aria-labelledby="agentchat-title">
  <div class="container">
    <div class="copy">
      <p class="eyebrow">CONTINUITY</p>
      <h2 id="agentchat-title">A persistent agent,<br />not a disappearing<br />prompt box.</h2>
      <p class="sub">
        Talk to an agent that stays with your work. Ask, refine, attach files,
        follow up — and restore a thread when you need it again.
      </p>
      <div class="meta">
        <span>· streaming</span><span>· thread memory</span><span>· restore</span>
      </div>
    </div>
    <div class="frame">
      <img
        src={asset('shots/agent-threads-transparent.webp')}
        width="2259"
        height="1435"
        loading="lazy"
        decoding="async"
        alt="codescribe agent chat — threads rail, tool activity, reasoned, streaming"
      />
    </div>
  </div>
</section>

<style>
  .agentchat {
    padding: 120px 24px;
    background: radial-gradient(70% 100% at 50% 0%, rgba(214, 178, 78, 0.05), transparent 60%);
  }
  .container {
    max-width: 1000px;
    display: flex;
    gap: 50px;
    align-items: center;
    flex-wrap: wrap;
  }
  .copy {
    flex: 1;
    min-width: 300px;
  }
  h2 {
    font: 700 clamp(32px, 4.6vw, 46px) / 1.04 var(--font-display);
    letter-spacing: -0.03em;
    margin: 16px 0 0;
    color: var(--ink);
  }
  .sub {
    font: 400 16px / 1.6 var(--font-display);
    color: var(--muted-2);
    margin: 22px 0 0;
    max-width: 420px;
  }
  .meta {
    display: flex;
    gap: 18px;
    margin-top: 26px;
    font: 500 12px var(--font-mono);
    color: var(--muted-3);
    flex-wrap: wrap;
  }
  .frame {
    flex: 1;
    min-width: 320px;
    border: 1px solid var(--stroke-2);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.5);
    max-height: 540px;
  }
  .frame img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    object-position: top;
  }
  @media (max-width: 480px) {
    .agentchat { padding: 84px 20px; }
  }
</style>
