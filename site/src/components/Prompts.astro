---
import { asset } from '../lib/asset';
---

<section class="section prompts" data-screen-label="Prompts" aria-labelledby="prompts-title">
  <div class="container">
    <div class="head">
      <p class="eyebrow">PERSONALIZATION</p>
      <h2 id="prompts-title">Make the agent yours.</h2>
      <p class="sub">
        Edit the prompts that drive formatting and assistive mode. Your voice.
        Your rules. Your agent.
      </p>
    </div>
    <div class="frame">
      <img
        src={asset('shots/prompt-transparent.webp')}
        width="2086"
        height="1600"
        loading="lazy"
        decoding="async"
        alt="codescribe Settings — Prompt editor: formatting.txt and assistive.txt"
      />
    </div>
    <div class="codecards">
      <div class="codecard">
        <div class="codecard__head">
          <span class="codecard__file codecard__file--olive">formatting.prompt</span>
          <span class="codecard__actions">edit · save · reset</span>
        </div>
        <p class="codecard__body">Keep my meaning exactly. Short sentences.<br />Prefer bullet points for lists. Never touch<br />code blocks. Always keep the original language.</p>
      </div>
      <div class="codecard">
        <div class="codecard__head">
          <span class="codecard__file codecard__file--terra">assistive.prompt</span>
          <span class="codecard__actions">edit · save · reset</span>
        </div>
        <p class="codecard__body">Return only the result, no preamble. Respect<br />scope — don't expand the task. Be operational.<br />Match my tone. Output a ready-to-run patch.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .prompts {
    padding: 120px 24px;
    background: radial-gradient(70% 100% at 50% 0%, rgba(217, 119, 87, 0.06), transparent 60%);
  }
  .container { max-width: 1000px; }
  .head {
    text-align: center;
    margin-bottom: 50px;
  }
  h2 {
    font: 700 clamp(32px, 5vw, 50px) / 1 var(--font-display);
    letter-spacing: -0.03em;
    margin: 16px 0 12px;
    color: var(--ink);
  }
  .sub {
    font: 400 16px / 1.55 var(--font-display);
    color: var(--muted-2);
    max-width: 460px;
    margin: 0 auto;
  }
  .frame {
    border: 1px solid var(--stroke-2);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.5);
    margin-bottom: 16px;
  }
  .frame img {
    width: 100%;
    height: auto;
    display: block;
  }
  .codecards {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .codecard {
    flex: 1;
    min-width: 300px;
    background: var(--bg-soft);
    border: 1px solid var(--stroke);
    border-radius: 14px;
    overflow: hidden;
  }
  .codecard__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid var(--line-soft);
  }
  .codecard__file {
    font: 600 12px var(--font-mono);
  }
  .codecard__file--olive { color: var(--olive-ink); }
  .codecard__file--terra { color: var(--terracotta-2); }
  .codecard__actions {
    font: 500 10px var(--font-mono);
    color: var(--muted-4);
  }
  .codecard__body {
    padding: 18px 16px;
    margin: 0;
    font: 500 12.5px / 1.8 var(--font-mono);
    color: #cfd2cb;
  }
  @media (max-width: 480px) {
    .prompts { padding: 84px 20px; }
  }
</style>
