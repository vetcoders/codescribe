---
// Interactive island A — hero live console (WEBSITE_SPEC §6, Island A).
// Server-renders the RESOLVED frame (CLEAN words visible + result strip) so the
// no-JS / reduced-motion experience is meaningful; the script re-drives the loop
// only when motion is allowed.
const CLEAN = 'Analyze the repo for duplicate event-dispatch — propose a minimal patch.'.split(' ');
---

<section class="hero" data-screen-label="Hero" aria-labelledby="hero-title">
  <div class="glow" aria-hidden="true"></div>

  <div class="inner">
    <p class="eyebrow eyebrow--hero">macOS · VOICE CONTROL LAYER</p>
    <h1 id="hero-title">
      Speak <span class="accent">in.</span> Code <span class="accent">out.</span>
    </h1>
    <p class="sub">
      Dictate, format, ask, remember, and dispatch work — from one always-available
      macOS overlay. Not voice typing. A voice interface to your tools and your agents.
    </p>

    <!-- live console -->
    <div class="console" data-console>
      <div class="console__head">
        <span class="rippledot" aria-hidden="true">
          <span class="rippledot__ring"></span>
          <span class="rippledot__ring rippledot__ring--delay"></span>
          <span class="rippledot__core"></span>
        </span>
        <span class="console__status" data-status>structured intent</span>
        <span class="console__engine">● local whisper</span>
      </div>
      <div class="console__body" data-body data-mode="clean">
        {CLEAN.map((w) => <span class="word word--in">{w}</span>)}
      </div>
      <div class="console__result" data-result data-reveal>
        <span class="console__resultdot" aria-hidden="true"></span>
        <span class="console__resulttext">handed to your agent · run started</span>
        <span class="console__resultmeta">2.4s · local</span>
      </div>
    </div>

    <div class="cta">
      <a class="btn btn--primary" href="#install">Install from source</a>
      <a class="btn btn--ghost" href="#modes">See the modes</a>
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">SCROLL ↓</div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 70px 24px 60px;
    overflow: hidden;
  }
  .glow {
    position: absolute;
    top: -12%;
    left: 50%;
    transform: translateX(-50%);
    width: 1000px;
    max-width: 100%;
    height: 640px;
    background: radial-gradient(50% 50% at 50% 50%, rgba(217, 119, 87, 0.17), transparent 70%);
    animation: breathe 7s ease-in-out infinite;
    pointer-events: none;
  }
  .inner {
    position: relative;
    text-align: center;
    max-width: 820px;
  }
  .eyebrow--hero {
    letter-spacing: 0.24em;
    text-transform: none;
  }
  h1 {
    font: 700 clamp(40px, 7.6vw, 80px) / 1 var(--font-display);
    letter-spacing: -0.04em;
    margin: 22px 0 0;
    color: var(--ink);
    white-space: nowrap;
  }
  .accent { color: var(--terracotta); }
  .sub {
    font: 400 18px / 1.55 var(--font-display);
    color: var(--muted);
    margin: 24px auto 0;
    max-width: 520px;
  }

  /* live console */
  .console {
    margin: 46px auto 0;
    max-width: 660px;
    background: var(--bg-chip);
    border: 1px solid var(--stroke);
    border-radius: 16px;
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.5);
    text-align: left;
    overflow: hidden;
  }
  .console__head {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 13px 18px;
    border-bottom: 1px solid var(--line-soft);
  }
  .rippledot {
    position: relative;
    display: inline-flex;
    width: 12px;
    height: 12px;
    align-items: center;
    justify-content: center;
    flex: none;
  }
  .rippledot__ring {
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1px solid var(--terracotta);
    animation: ripple 2.6s ease-out infinite;
  }
  .rippledot__ring--delay { animation-delay: 1.3s; }
  .rippledot__core {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--terracotta);
    animation: softpulse 2.6s ease-in-out infinite;
  }
  .console__status {
    font: 500 11px var(--font-mono);
    color: var(--muted-3);
    letter-spacing: 0.08em;
  }
  .console__engine {
    margin-left: auto;
    font: 500 10px var(--font-mono);
    color: var(--olive);
  }
  .console__body {
    padding: 24px 22px;
    min-height: 104px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    /* Inter-word gap lives on the flex container (not per-.word margin) so it
       also reaches the JS-recreated word spans, which don't carry Astro's
       scoped data-astro-cid attribute the scoped .word rule targets. */
    column-gap: 0.32em;
    font: 500 19px / 1.55 var(--font-display);
    color: var(--muted);
  }
  .console__body[data-mode='clean'] { color: var(--ink-3); }
  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(10px);
    filter: blur(3px);
    transition: opacity 0.55s ease, transform 0.55s ease, filter 0.55s ease;
  }
  .word--in {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
  .console__result {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 13px 22px;
    border-top: 1px solid var(--line-soft);
    background: rgba(95, 107, 62, 0.06);
    animation: floatIn 0.4s ease both;
  }
  .console__result[hidden] { display: none; }
  .console__resultdot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--olive-ink);
    box-shadow: 0 0 10px 1px rgba(157, 177, 120, 0.5);
    flex: none;
  }
  .console__resulttext {
    font: 500 12px var(--font-mono);
    color: var(--olive-ink);
  }
  .console__resultmeta {
    margin-left: auto;
    font: 500 11px var(--font-mono);
    color: var(--muted-4);
  }

  .cta {
    display: flex;
    gap: 13px;
    justify-content: center;
    margin-top: 38px;
    flex-wrap: wrap;
  }
  .btn {
    text-decoration: none;
    padding: 14px 26px;
    border-radius: 11px;
    font: 600 14px var(--font-display);
  }
  .btn--primary {
    background: var(--terracotta);
    color: #0a0a0a;
    box-shadow: 0 8px 24px rgba(217, 119, 87, 0.3);
  }
  .btn--ghost {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--stroke-3);
    color: var(--ink-2);
  }
  .scroll-hint {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    font: 500 10px var(--font-mono);
    color: var(--scroll-hint);
    letter-spacing: 0.2em;
    animation: drift 3s ease-in-out infinite;
  }

  @media (max-width: 480px) {
    h1 { white-space: normal; }
    .hero { padding: 56px 20px 48px; }
  }
</style>

<script>
  const RAW = 'uh, so scan this repo and fix the double-sent events'.split(' ');
  const CLEAN = 'Analyze the repo for duplicate event-dispatch — propose a minimal patch.'.split(' ');

  const body = document.querySelector<HTMLElement>('[data-body]');
  const statusEl = document.querySelector<HTMLElement>('[data-status]');
  const result = document.querySelector<HTMLElement>('[data-result]');

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Reduced motion / no target: leave the server-rendered resolved frame as-is.
  if (body && statusEl && result && !reduce) {
    let alive = true;
    const wait = (ms: number) => new Promise((res) => setTimeout(res, ms));

    function setMode(mode: 'raw' | 'clean') {
      body!.dataset.mode = mode;
      const words = mode === 'raw' ? RAW : CLEAN;
      body!.innerHTML = '';
      for (const w of words) {
        const span = document.createElement('span');
        span.className = 'word';
        span.textContent = w;
        body!.appendChild(span);
        // Whitespace between words: keeps the transcript readable (and
        // copy-/screen-reader-correct) instead of "uh,soscanthisrepo".
        body!.appendChild(document.createTextNode(' '));
      }
    }

    function setStatus(mode: 'raw' | 'clean', showResult: boolean) {
      statusEl!.textContent =
        mode === 'clean' ? (showResult ? 'structured intent' : 'shaping intent…') : 'listening…';
    }

    async function reveal(mode: 'raw' | 'clean', per: number) {
      if (!alive) return;
      setMode(mode);
      setStatus(mode, false);
      result!.hidden = true;
      await wait(60);
      const spans = body!.querySelectorAll<HTMLElement>('.word');
      for (let i = 0; i < spans.length; i++) {
        if (!alive) return;
        spans[i].classList.add('word--in');
        await wait(per);
      }
    }

    async function loop() {
      // Start from a clean slate rather than the pre-rendered resolved frame.
      result!.hidden = true;
      while (alive) {
        await wait(650);
        await reveal('raw', 150);
        await wait(1000);
        if (!alive) return;
        await reveal('clean', 115);
        if (!alive) return;
        setStatus('clean', true);
        result!.hidden = false;
        await wait(2700);
      }
    }

    loop();
    window.addEventListener('beforeunload', () => {
      alive = false;
    });
  }
</script>
