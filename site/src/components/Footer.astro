---
import { asset } from '../lib/asset';
// Footer (WEBSITE_SPEC §3). Brand line corrected to "Vetcoders" (capital V only).
---

<footer class="footer" data-screen-label="Footer">
  <div class="container">
    <div class="brand">
      <img src={asset('icon.png')} width="26" height="26" alt="" />
      <span class="wordmark">codescribe</span>
    </div>
    <nav class="links" aria-label="Footer">
      <a href="https://github.com/vetcoders/codescribe" target="_blank" rel="noopener noreferrer">github ↗</a>
      <a href="https://github.com/vetcoders/codescribe#readme" target="_blank" rel="noopener noreferrer">docs</a>
      <a href="https://github.com/vetcoders/codescribe/releases" target="_blank" rel="noopener noreferrer">releases</a>
    </nav>
    <div class="legal">Vetcoders · Libraxis AI · FSL-1.1-ALv2</div>
  </div>
</footer>

<style>
  .footer {
    padding: 50px 24px;
    border-top: 1px solid var(--hairline);
  }
  .container {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 11px;
  }
  .wordmark {
    font: 700 17px var(--font-display);
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .links {
    display: flex;
    gap: 24px;
    font: 500 12px var(--font-mono);
    color: var(--muted-3);
  }
  .links a {
    text-decoration: none;
    color: inherit;
  }
  .links a:hover { color: var(--ink-2); }
  .legal {
    font: 500 11px var(--font-mono);
    color: var(--scroll-hint);
  }
</style>
