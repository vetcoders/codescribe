---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import LivesOverYourWork from '../components/LivesOverYourWork.astro';
import Modes from '../components/Modes.astro';
import Formatting from '../components/Formatting.astro';
import Selection from '../components/Selection.astro';
import AgentChat from '../components/AgentChat.astro';
import VoiceDrawer from '../components/VoiceDrawer.astro';
import Prompts from '../components/Prompts.astro';
import AgentStack from '../components/AgentStack.astro';
import ControlLayer from '../components/ControlLayer.astro';
import MacNative from '../components/MacNative.astro';
import Onboarding from '../components/Onboarding.astro';
import Install from '../components/Install.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <main id="main">
    <Hero />
    <LivesOverYourWork />
    <Modes />
    <Formatting />
    <Selection />
    <AgentChat />
    <VoiceDrawer />
    <Prompts />
    <AgentStack />
    <ControlLayer />
    <MacNative />
    <Onboarding />
    <Install />
  </main>
  <Footer />
