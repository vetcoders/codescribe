WHISPER_LANGUAGE=pl_or_en_or_auto
AGENT_NAME=MyAgent
AUTO_SILENCE=1
BEEP_ON_START=1
DOUBLE_OPTION_INTERVAL_MS=350
DUMP_AUDIO_LOGS=0
ENABLE_DOUBLE_OPTION=1
# FORMAT_ENABLED legacy; use ai_formatting_enabled in settings
FORMAT_ENABLED=1
FORMAT_STRATEGY=light_plus
HARMONY_API_KEY=sk-...
HARMONY_BASE_URL=https://api.example.com/v1
HARMONY_MODEL=gpt-4o-mini
HISTORY_ENABLED=1
HOLD_EXCLUSIVE=1
HOLD_MODS=ctrl
HOLD_START_DELAY_MS=800
HOLD_STREAMING=1
HOTKEYS_DEBUG=0
LOG_LEVEL=INFO
MAX_NEW_TOKENS=2048
MODE=hold
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
RESTORE_CLIPBOARD=1
RESTORE_CLIPBOARD_DELAY_MS=200
TEMPERATURE=0.2
TOGGLE_TRIGGER=double_option
TOP_P=0.0
# VISTASCRIBE_DATA_DIR='$HOME/.vistascribe'
WHISPER_DIR=models/whisper-small
WHISPER_VARIANT=small