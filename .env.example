# CodeScribe Configuration
# Copy to ~/.CodeScribe/.env and customize
#
# Created by M&K (c)2025 The LibraxisAI Team

# =============================================================================
# WHISPER MODEL (Local MLX)
# =============================================================================
WHISPER_VARIANT=large-v3-turbo
WHISPER_LANGUAGE=pl
# WHISPER_DIR=                    # Optional: custom model path

# =============================================================================
# CLOUD STT (optional - if set, uses cloud instead of local)
# =============================================================================
# STT_ENDPOINT=https://api.libraxis.cloud/v1/audio/transcriptions   # FULL endpoint!
# STT_API_KEY=your-api-key

# =============================================================================
# HOTKEYS
# =============================================================================
HOLD_MODS=ctrl                    # ctrl | ctrl_alt | ctrl_shift | ctrl_cmd
TOGGLE_TRIGGER=double_option      # double_option | double_ralt | none

# =============================================================================
# AI FORMATTING
# =============================================================================
AI_FORMATTING_ENABLED=1
LLM_HOST=http://127.0.0.1:11434/v1/responses   # FULL endpoint path!
LLM_MODEL=qwen3:32b
# LLM_API_KEY=                    # Required for cloud LLM

# =============================================================================
# DEBUG
# =============================================================================
LOG_LEVEL=INFO
# DUMP_AUDIO_LOGS=0               # Set to 1 to save audio files for debugging
