# VistaScribe — default environment template
# Copy this file to `.env` (or source it in your launcher) and override only what you need.
# All variables are optional; sane defaults are embedded in the tray/backend.

# Logging & appearance
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
SHOW_TRAY_GLYPH=1           # 1=show Unicode glyph next to the tray icon
BEEP_ON_START=0             # 1=play the confirmation chime when recording begins
HISTORY_ENABLED=1           # 1=persist transcripts to ~/Library/Application Support/VistaScribe/History
HOLD_MODS=ctrl              # ctrl | ctrl+alt | ctrl+shift | ctrl+cmd (see Hotkeys menu)
HOLD_EXCLUSIVE=1            # 1=require exactly HOLD_MODS, ignoring extra modifiers
TOGGLE_TRIGGER=double_option  # double_option | double_ralt | double_space | none

# Whisper / STT
WHISPER_VARIANT=large-v3-turbo    # small | medium | large-v3 | large-v3-turbo
WHISPER_DIR=models/whisper-large-v3-turbo
WHISPER_LANGUAGE=                 # pl | en | (empty = auto)
WHISPER_SERVER_URL=               # Optional remote STT endpoint (overrides local model)
VISTASCRIBE_HOST=127.0.0.1        # Hostname used by tray tools/clients to reach the backend

# AI formatting providers
HARMONY_BASE_URL=            # Required when Harmony provider selected, e.g. https://api.libraxis.cloud/llm/v1
HARMONY_API_KEY=                  # Harmony/OpenAI-compatible API key (if using remote formatting)
HARMONY_MODEL=gpt-4o-mini         # Model passed to Harmony `/v1/responses`
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
TEMPERATURE=0.20
TOP_P=0.0

# Settings store (optional override; defaults to ~/Library/Application Support/VistaScribe/settings.json)
VISTASCRIBE_SETTINGS_PATH=
