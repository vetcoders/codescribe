# CodeScribe .env (minimal + recommended)
# Source of truth: docs/env.md
# Copy: cp .env.example ~/.codescribe/.env

# =============================================================================
# LOCAL EMBEDDED (RECOMMENDED)
# =============================================================================
USE_LOCAL_STT=1
WHISPER_LANGUAGE=pl
LOCAL_MODEL=whisper-large-v3-turbo-mlx-q8

# =============================================================================
# AI FORMATTING (OPTIONAL)
# =============================================================================
# AI_FORMATTING_ENABLED=1
# LLM_ENDPOINT=https://api.openai.com/v1/responses
# LLM_MODEL=gpt-4.1-mini
# LLM_API_KEY=sk-...

# Formatting overrides (optional)
# LLM_FORMATTING_ENDPOINT=
# LLM_FORMATTING_MODEL=
# LLM_FORMATTING_API_KEY=

# Assistive overrides (optional)
# LLM_ASSISTIVE_ENDPOINT=
# LLM_ASSISTIVE_MODEL=
# LLM_ASSISTIVE_API_KEY=

# =============================================================================
# CLOUD STT (OPTIONAL, CLOUD-ONLY)
# =============================================================================
# USE_LOCAL_STT=0
# STT_ENDPOINT=https://api.libraxis.cloud/v1/audio/transcriptions
# STT_API_KEY=...

# =============================================================================
# STREAMING TUNING (OPTIONAL)
# =============================================================================
# CODESCRIBE_STREAM_CHUNK_SEC=12
# CODESCRIBE_STREAM_OVERLAP_RATIO=0.25
# CODESCRIBE_STREAM_SIMILARITY=0.90
# CODESCRIBE_STREAM_NOVELTY=0.20
