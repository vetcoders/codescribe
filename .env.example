# CodeScribe Configuration
# Copy to ~/.codescribe/.env and customize
#
# Created by M&K (c)2026 VetCoders

# =============================================================================
# WHISPER MODEL (Local MLX - embedded in binary by default)
# =============================================================================
WHISPER_LANGUAGE=pl                  # pl | en (no auto!)
# WHISPER_VARIANT=large-v3-turbo     # Only if using external model
# WHISPER_DIR=                       # Custom model directory path
# CODESCRIBE_MODEL_PATH=             # Override embedded model with external

# =============================================================================
# CLOUD STT (optional - fallback if local fails)
# =============================================================================
# STT_ENDPOINT=https://api.libraxis.cloud/v1/audio/transcriptions
# STT_API_KEY=your-stt-api-key
# USE_LOCAL_STT=1                    # 1=prefer local, 0=cloud only

# =============================================================================
# HOTKEYS
# =============================================================================
HOLD_MODS=ctrl                       # ctrl | ctrl_alt | ctrl_shift | ctrl_cmd
HOLD_EXCLUSIVE=0                     # 1=disable other hotkeys during hold
TOGGLE_TRIGGER=double_option         # double_option | double_ralt | none
HOLD_START_DELAY_MS=800              # Delay before recording starts (hold mode)

# =============================================================================
# LLM CONFIG - Provider Separation
# Contract: LLM_{FORMATTING,ASSISTIVE}_{ENDPOINT,MODEL,API_KEY}
# =============================================================================

# Shared defaults (used if mode-specific not set)
LLM_ENDPOINT=https://api.openai.com/v1/responses    # FULL URL!
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=sk-proj-...

# Formatting mode overrides (Ctrl hold - cleanup only)
# LLM_FORMATTING_ENDPOINT=
# LLM_FORMATTING_MODEL=
# LLM_FORMATTING_API_KEY=

# Assistive mode overrides (Ctrl+Shift - AI augmentation)
# LLM_ASSISTIVE_ENDPOINT=https://api.libraxis.cloud/v1/responses
# LLM_ASSISTIVE_MODEL=claude-opus-4-5-20251101
# LLM_ASSISTIVE_API_KEY=vista-...

# =============================================================================
# AI FORMATTING BEHAVIOR
# =============================================================================
AI_FORMATTING_ENABLED=1              # 1=format via LLM, 0=raw transcript only
# AI_PROVIDER=harmony                # Legacy - use LLM_ENDPOINT instead

# =============================================================================
# HISTORY & AUDIO
# =============================================================================
HISTORY_ENABLED=1                    # Save transcripts to ~/.codescribe/transcriptions/
DUMP_AUDIO_LOGS=0                    # 1=save .wav paired with .txt (Keep Audio)

# =============================================================================
# UI & FEEDBACK
# =============================================================================
SHOW_TRAY_GLYPH=1                    # Show status glyph in tray
HOLD_INDICATOR=badge                 # badge | overlay | none
HOLD_BADGE_SIZE=18
HOLD_BADGE_OFFSET_X=0
HOLD_BADGE_OFFSET_Y=0
BEEP_ON_START=1                      # Audio feedback on recording start
SOUND_NAME=Funk                      # macOS sound name
SOUND_VOLUME=0.5                     # 0.0 - 1.0

# =============================================================================
# CLIPBOARD
# =============================================================================
RESTORE_CLIPBOARD=1                  # Restore clipboard after paste
RESTORE_CLIPBOARD_DELAY_MS=300       # Delay before restore

# =============================================================================
# AUDIO INPUT
# =============================================================================
# AUDIO_INPUT_DEVICE=                # Specific device name (default: system)
SILENCE_DB=-40                       # Silence threshold in dB
SILENCE_HANG_SEC=0.8                 # Seconds of silence before auto-stop
AUTO_SILENCE=0                       # 1=auto-stop on silence (toggle mode)

# =============================================================================
# DEBUG & DEVELOPMENT
# =============================================================================
LOG_LEVEL=INFO                       # TRACE | DEBUG | INFO | WARN | ERROR
# CODESCRIBE_DEBUG_TOKENS=1          # Show token-level transcription
# CODESCRIBE_AI_MAX_RETRIES=2        # LLM retry attempts
# CODESCRIBE_AI_RETRY_DELAY_MS=500   # Delay between retries
# CODESCRIBE_AI_ATTEMPT_TIMEOUT_MS=5000  # Single attempt timeout

# =============================================================================
# SYSTEM (usually not needed)
# =============================================================================
START_AT_LOGIN=0                     # Auto-start via launchd
# CODESCRIBE_DATA_DIR=               # Override ~/.codescribe
# CODESCRIBE_ENV_PATH=               # Custom .env location
# BACKEND_MAX_UPLOAD_MB=25           # Max audio upload size
